{
  "info": {
    "name": "SmartBank Metrics API",
    "description": "Collection complète pour tester et visualiser les données DORA & Performance Équipe",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [

    {
      "name": "🔧 System",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('DB connected', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('ok');",
                  "    pm.expect(body.database).to.eql('connected');",
                  "});",
                  "pm.test('Commits en base > 0', () => {",
                  "    pm.expect(pm.response.json().commits_in_db).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Vérifie que l'API et PostgreSQL sont opérationnels"
          }
        },
        {
          "name": "Stats Globales",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Toutes les tables ont des données', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.jira_rows).to.be.above(0);",
                  "    pm.expect(body.commits_rows).to.be.above(0);",
                  "    pm.expect(body.pipelines_rows).to.be.above(0);",
                  "    pm.expect(body.jobs_rows).to.be.above(0);",
                  "    pm.expect(body.tickets_rows).to.be.above(0);",
                  "});",
                  "// Afficher le résumé dans la console",
                  "console.log('=== STATS BASE DE DONNÉES ===');",
                  "const b = pm.response.json();",
                  "Object.keys(b).forEach(k => console.log(k + ': ' + b[k]));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/stats",
            "description": "Nombre de lignes dans chaque table de la base"
          }
        }
      ]
    },

    {
      "name": "🧹 Cleaned - Jira",
      "item": [
        {
          "name": "Jira - Toutes les données",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Pagination présente', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('total');",
                  "    pm.expect(body).to.have.property('data');",
                  "    pm.expect(body.data).to.be.an('array');",
                  "});",
                  "pm.test('Total > 3000 lignes', () => {",
                  "    pm.expect(pm.response.json().total).to.be.above(3000);",
                  "});",
                  "pm.test('Colonnes correctes', () => {",
                  "    const row = pm.response.json().data[0];",
                  "    pm.expect(row).to.have.property('ticket_key');",
                  "    pm.expect(row).to.have.property('status');",
                  "    pm.expect(row).to.have.property('assignee');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/cleaned/jira?limit=50&offset=0",
              "query": [
                {"key": "limit", "value": "50"},
                {"key": "offset", "value": "0"}
              ],
              "host": ["{{base_url}}"],
              "path": ["cleaned", "jira"]
            }
          }
        },
        {
          "name": "Jira - Filtrer par projet DL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tous les tickets sont DL', () => {",
                  "    pm.response.json().data.forEach(row => {",
                  "        pm.expect(row.project_key).to.eql('DL');",
                  "    });",
                  "});",
                  "pm.test('Projet DL a des tickets', () => {",
                  "    pm.expect(pm.response.json().total).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/cleaned/jira?project=DL&limit=20",
              "query": [
                {"key": "project", "value": "DL"},
                {"key": "limit", "value": "20"}
              ],
              "host": ["{{base_url}}"],
              "path": ["cleaned", "jira"]
            },
            "description": "Filtrer les tickets du projet Data Lake"
          }
        },
        {
          "name": "Jira - Filtrer statut Blocked",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tickets Blocked retournés', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.total).to.be.above(0);",
                  "    body.data.forEach(row => {",
                  "        pm.expect(row.status.toLowerCase()).to.eql('blocked');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/cleaned/jira?status=Blocked&limit=20",
              "query": [
                {"key": "status", "value": "Blocked"},
                {"key": "limit", "value": "20"}
              ],
              "host": ["{{base_url}}"],
              "path": ["cleaned", "jira"]
            }
          }
        }
      ]
    },

